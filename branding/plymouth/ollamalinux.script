# OllamaLinux Plymouth Boot Script
# Simple text-based spinner

fun refresh_callback() {
    sprite.SetImage(logo.image);
    sprite.SetPosition(Window.GetWidth() / 2 - logo.image.GetWidth() / 2,
                       Window.GetHeight() / 2 - logo.image.GetHeight() / 2);
}

Plymouth.SetRefreshFunction(refresh_callback);
