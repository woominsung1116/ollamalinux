#!/bin/bash
set -euo pipefail

echo ">>> Installing Open WebUI..."

WEBUI_DIR="/opt/open-webui"
WEBUI_USER="openwebui"

useradd -r -s /bin/false -U -m -d "$WEBUI_DIR" "$WEBUI_USER" 2>/dev/null || true

python3 -m venv "$WEBUI_DIR/venv"
source "$WEBUI_DIR/venv/bin/activate"
pip install --no-cache-dir --retries 5 --timeout 60 open-webui
deactivate

mkdir -p "$WEBUI_DIR/data"
chown -R "$WEBUI_USER:$WEBUI_USER" "$WEBUI_DIR"

mkdir -p /etc/ollamalinux
cat > /etc/ollamalinux/open-webui.conf <<'CONF'
OPEN_WEBUI_PORT=8080
OLLAMA_BASE_URL=http://127.0.0.1:11434
DATA_DIR=/opt/open-webui/data
WEBUI_AUTH=true
CONF

echo ">>> Open WebUI installed successfully."
